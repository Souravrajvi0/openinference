# App
NODE_ENV=development
LOG_LEVEL=info

# Gateway
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
JWT_SECRET=change-me-in-production-use-32-chars-min
APP_URL=https://openinference.tech

# Google OAuth (optional — enables "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails granted the 'admin' role/scope. Everyone else who signs
# up is a regular user (chat + retrieve + agent only — no keys/budgets/traces).
ADMIN_EMAILS=souravrajvi@gmail.com

# Database
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/openinference
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis — use local Docker Redis in production (see docker-compose.yml).
# Do NOT point at a managed read replica; the gateway requires writes (rate limits, queues).
REDIS_URL=redis://localhost:6379

# LLM Providers (add only the ones you use)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
CEREBRAS_API_KEY=csk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Self-hosted inference via Ollama (OpenAI-compatible). No API key required.
# e.g. http://ollama:11434 (compose service) or http://host:11434
OLLAMA_URL=http://ollama:11434

# Default model routing
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile
FALLBACK_PROVIDER=groq
FALLBACK_MODEL=llama-3.1-8b-instant

# Embedding (Mistral)
MISTRAL_EMBEDDING_MODEL=mistral-embed
EMBEDDING_DIMENSIONS=1024

# Rate limits (per API key, per minute)
DEFAULT_RATE_LIMIT_RPM=60
DEFAULT_RATE_LIMIT_TPM=100000

# Eval worker
EVAL_MODEL=llama-3.3-70b-versatile
EVAL_QUEUE_CONCURRENCY=5

# Ingestion worker
INGEST_QUEUE_CONCURRENCY=3
MAX_CHUNK_SIZE=512
CHUNK_OVERLAP=64
