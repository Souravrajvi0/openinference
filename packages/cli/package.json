{
  "name": "@openinference/cli",
  "version": "1.6.1",
  "description": "OpenInference Core — a hardware-aware package manager for local AI models: search, install, run, and chat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Souravrajvi0/openinference.git",
    "directory": "packages/cli"
  },
  "homepage": "https://openinference.tech/cli",
  "bin": {
    "oi": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build": "node scripts/build-catalog.mjs && tsc && node -e \"require('fs').cpSync('data','dist/data',{recursive:true})\"",
    "catalog": "node scripts/build-catalog.mjs",
    "verify-catalog": "node scripts/verify-catalog.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
